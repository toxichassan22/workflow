# Z.ai API Key (required for GLM-5.1 text generation)
ZAI_KEY=your-zai-api-key-here

# OpenRouter API Key (required for image generation via Gemini)
OPENROUTER_KEY=your-openrouter-api-key-here

# Google Maps API Key (required for map slides)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Google Maps API rate limiting (calls per window in seconds)
# Default: 60 calls per 10 minutes per tenant
MAPS_RATE_LIMIT=60
MAPS_RATE_WINDOW=600
